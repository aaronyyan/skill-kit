{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SkillKit",
  "version": "0.1.2",
  "identifier": "dev.yanlixing.skillkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SkillKit",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "macOS": {
      "dmg": {
        "background": "assets/dmg-background.png",
        "windowSize": {
          "width": 720,
          "height": 440
        },
        "appPosition": {
          "x": 188,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 532,
          "y": 200
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
